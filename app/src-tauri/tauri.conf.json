{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "COCO Parking",
  "version": "0.2.1",
  "identifier": "com.cocoparking.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "COCO Parking",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' asset:",
        "connect-src": "ipc: http://ipc.localhost http://localhost:5173 https://api.github.com",
        "img-src": "'self' asset: data: blob:",
        "style-src": "'self' 'unsafe-inline'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": null,
      "timestampUrl": ""
    },
    "longDescription": "COCO Parking - Smart Parking Dashboard. Desktop app for parking management.",
    "shortDescription": "Smart Parking Dashboard",
    "category": "Business",
    "publisher": "COCO Parking",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYyNTk4NUQyNEQwMTM1MUYKUldRZk5RRk4wb1ZaWXVQdWxJZTlScFFSbmVLRkFlMS80VUF2cERMb3NMMFRvenNoeHJxS3ZramcK",
      "endpoints": [
        "https://api.github.com/repos/Esteban12j/coco_parking/releases/latest"
      ]
    }
  }
}